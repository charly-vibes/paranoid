<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Text -->
    <color name="text_primary">#FFCCCCCC</color>      <!-- main body text on dark bg -->
    <color name="text_secondary">#FF888888</color>    <!-- muted/captions -->
    <color name="text_emphasis">#FFE0E0E0</color>     <!-- emphasised body text -->
    <color name="text_subtle">#FF555555</color>       <!-- borders, very low contrast -->
    <color name="text_inverse">#FFFFFFFF</color>      <!-- white-on-color chips -->

    <!-- Accents / status -->
    <color name="accent_warning">#FFFFB74D</color>    <!-- orange (totals, warning chips) -->
    <color name="status_ok">#FF4CAF50</color>         <!-- green (identical) -->
    <color name="status_critical">#FFFF5252</color>   <!-- red (critical / both degraded) -->
    <color name="status_info">#FF64B5F6</color>       <!-- light blue (info / minor diff) -->

    <!-- Surfaces -->
    <color name="surface_chip">#FF333333</color>      <!-- chip / card background -->
</resources>
