<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="←"
                android:textColor="#CCCCCC"
                android:textSize="20sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_detail_title"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/app_detail_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/app_detail_uninstalled_indicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_detail_uninstalled_indicator"
            android:textColor="#FFB74D"
            android:textSize="13sp"
            android:textStyle="italic"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/app_detail_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/app_detail_total"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFB74D"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_detail_total_label"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/app_detail_no_activity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_detail_no_activity"
            android:textColor="#888888"
            android:textSize="14sp"
            android:textStyle="italic"
            android:background="@drawable/app_item_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/app_detail_intervals_heading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_detail_intervals_heading"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/app_detail_intervals_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
