<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <org.maplibre.android.maps.MapView
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Signal HUD -->
    <LinearLayout
        android:id="@+id/signal_hud"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="88dp"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        android:background="@drawable/app_item_bg"
        android:padding="12dp"
        android:minWidth="100dp">

        <TextView
            android:id="@+id/hud_rsrp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="— dBm"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/hud_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No signal"
            android:textColor="#888888"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/hud_network"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#666666"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingBottom="8dp"
        android:background="#CC121212"
        android:fitsSystemWindows="true">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="←"
            android:textColor="#CCCCCC"
            android:textSize="20sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NetMap"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_antenna_toggle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="📡"
            android:textColor="#666666"
            android:textSize="18sp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Show antennas" />

        <TextView
            android:id="@+id/btn_recordings"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Recordings"
            android:textColor="#888888"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Antenna disclosure (visible when antenna layer is enabled) -->
    <TextView
        android:id="@+id/antenna_disclosure"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="64dp"
        android:layout_marginStart="12dp"
        android:background="@drawable/app_item_bg"
        android:padding="6dp"
        android:text="Approximate — based on observed signal"
        android:textColor="#AAAAAA"
        android:textSize="10sp"
        android:visibility="gone" />

    <!-- Bottom controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp"
        android:paddingBottom="32dp"
        android:fitsSystemWindows="true">

        <TextView
            android:id="@+id/recording_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btn_record"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="Start Recording"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/app_item_bg"
            android:clickable="true"
            android:focusable="true"
            android:enabled="false"
            android:alpha="0.5" />

        <TextView
            android:id="@+id/permission_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grant location and phone permissions to start"
            android:textColor="#666666"
            android:textSize="11sp"
            android:layout_marginTop="8dp"
            android:gravity="center" />
    </LinearLayout>
</FrameLayout>
